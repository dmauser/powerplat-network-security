# Squad: ignore runtime state (logs, sessions, scratch)
# Allow timestamped orchestration and session logs (managed by Scribe)
.squad/orchestration-log/
!.squad/orchestration-log/*.md
.squad/log/
!.squad/log/*.md
# decisions/inbox is the agent drop-box — MUST be tracked (do NOT add it here)
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Azure deployment artifacts
.azure/

# Azure CLI / azd state
.azure/

# Bicep build artifacts
infra/**/*.json
!infra/dev.parameters.json
infra/**/*.json.tmp
**/main.json
**/*.compiled.json

# PowerShell module cache
.psmodules/
*.psd1.bak

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Secrets / local overrides
*.local.*
*.secret
secrets.env
local.settings.json

